<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToHeight="true" fitToWidth="true" styleClass="scroll-pane-transparent" stylesheets="@../../core/css/globalStyles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.grupo1.sgsm.ventasYfacturacion.controller.consultarFacturasUIOOperativoController">
    <content>
        <VBox alignment="TOP_CENTER" styleClass="main-bg">
            <children>
                <VBox alignment="TOP_LEFT" maxWidth="1200.0" spacing="20.0" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
                    </padding>
                    <children>

                        <!-- Títulos -->
                        <VBox spacing="2.0">
                            <children>
                                <Label styleClass="page-title" text="CONSULTA GENERAL DE FACTURAS" />
                                <Label styleClass="page-subtitle" text="Búsqueda y filtrado de comprobantes emitidos entre rangos de fechas" />
                            </children>
                        </VBox>

                        <!-- Tarjeta de Filtros -->
                        <HBox alignment="BOTTOM_LEFT" spacing="20.0" styleClass="form-card">
                            <padding>
                                <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
                            </padding>
                            <children>
                                <!-- Fecha Inicio -->
                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="input-label" text="Fecha Inicio" />
                                        <DatePicker fx:id="dpFechaInicio" prefWidth="180.0" promptText="dd/mm/aaaa" styleClass="form-field-standalone" />
                                    </children>
                                </VBox>

                                <!-- Fecha Fin -->
                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="input-label" text="Fecha Fin" />
                                        <DatePicker fx:id="dpFechaFin" prefWidth="180.0" promptText="dd/mm/aaaa" styleClass="form-field-standalone" />
                                    </children>
                                </VBox>

                                <!-- Botón Filtrar -->
                                <Button fx:id="btnFiltrar" mnemonicParsing="false" onAction="#filtrarFacturas" styleClass="btn-primary">
                                    <graphic>
                                        <HBox alignment="CENTER" spacing="8.0">
                                            <children>
                                                <Label fx:id="lblIconFiltrar" styleClass="btn-primary-icon-font" />
                                                <Label styleClass="btn-primary-text" text="Filtrar" />
                                            </children>
                                        </HBox>
                                    </graphic>
                                </Button>
                            </children>
                        </HBox>

                        <!-- Contenedor de la Tabla y Paginación -->
                        <VBox styleClass="form-card" VBox.vgrow="ALWAYS">
                            <children>

                                <!-- Tabla -->
                                <TableView fx:id="tbFacturas" styleClass="custom-table" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colNumeroFactura" prefWidth="250.0" text="NÚMERO DE FACTURA" />
                                        <TableColumn fx:id="colFechaEmision" prefWidth="150.0" text="FECHA DE EMISIÓN" />
                                        <TableColumn fx:id="colCedulaCliente" prefWidth="200.0" text="CÉDULA DEL CLIENTE" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>

                                <!-- Paginación (Simulada visualmente) -->
                                <HBox alignment="CENTER_LEFT" styleClass="card-footer">
                                    <children>
                                        <Label fx:id="lblPaginacion" style="-fx-font-size: 12px; -fx-text-fill: #555555; -fx-font-weight: bold;" text="Mostrando 0 de 0 comprobantes" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <HBox spacing="15.0">
                                            <children>
                                                <Label fx:id="lblIconPrev" style="-fx-cursor: hand; -fx-text-fill: #888888;" />
                                                <Label fx:id="lblIconNext" style="-fx-cursor: hand; -fx-text-fill: #111111;" />
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>

                            </children>
                        </VBox>

                        <!-- Footer de Acciones (Factura seleccionada y Botón) -->
                        <HBox alignment="CENTER_LEFT">
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                            <children>
                                <!-- Texto dinámico -->
                                <Label fx:id="lblFacturaSeleccionada" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #555555;" text="Factura seleccionada: Ninguna" />

                                <Region HBox.hgrow="ALWAYS" />

                                <!-- Botón Ver Detalles (Deshabilitado por defecto) -->
                                <Button fx:id="btnVerCompleta" disable="true" mnemonicParsing="false" onAction="#verInformacionCompleta" styleClass="btn-primary">
                                    <graphic>
                                        <HBox alignment="CENTER" spacing="8.0">
                                            <children>
                                                <Label fx:id="lblIconVer" styleClass="btn-primary-icon-font" />
                                                <Label styleClass="btn-primary-text" text="Ver Información Completa" />
                                            </children>
                                        </HBox>
                                    </graphic>
                                </Button>
                            </children>
                        </HBox>

                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>