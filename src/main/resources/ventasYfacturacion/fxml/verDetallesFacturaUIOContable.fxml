<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToHeight="true" fitToWidth="true" styleClass="scroll-pane-transparent" stylesheets="@../../core/css/globalStyles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.grupo1.sgsm.ventasYfacturacion.controller.verDetallesFacturaUIOContableController">
    <content>
        <VBox alignment="TOP_CENTER" styleClass="main-bg">
            <children>
                <!-- Contenedor Principal Responsivo -->
                <VBox alignment="TOP_LEFT" maxWidth="1200.0" spacing="20.0" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
                    </padding>
                    <children>

                        <!-- Cabecera: Títulos, Privacidad y Botón Volver -->
                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                            <children>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="page-title" text="DETALLE DE COMPROBANTE" />
                                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                                            <children>
                                                <!-- Badge de Sede -->
                                                <HBox alignment="CENTER" spacing="5.0" style="-fx-background-color: #000000; -fx-padding: 4 10; -fx-background-radius: 4;">
                                                    <children>
                                                        <Label fx:id="lblIconSede" style="-fx-text-fill: white; -fx-font-size: 12px;" />
                                                        <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11px;" text="Sede: QUITO" />
                                                    </children>
                                                </HBox>
                                                <!-- Texto de privacidad -->
                                                <Label style="-fx-text-fill: #888888; -fx-font-size: 12px; -fx-font-style: italic; -fx-font-weight: bold;" text="Modo de visualización por privacidad activado" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <Region HBox.hgrow="ALWAYS" />

                                <Button fx:id="btnVolver" mnemonicParsing="false" onAction="#volverAlListado" styleClass="btn-transparent">
                                    <graphic>
                                        <HBox alignment="CENTER" spacing="8.0">
                                            <children>
                                                <Label fx:id="lblIconVolver" style="-fx-text-fill: #888888; -fx-font-size: 16px;" />
                                                <Label style="-fx-text-fill: #888888; -fx-font-weight: bold; -fx-font-size: 13px;" text="VOLVER AL LISTADO" />
                                            </children>
                                        </HBox>
                                    </graphic>
                                </Button>
                            </children>
                        </HBox>

                        <!-- Tarjeta 1: Datos Contables Básicos -->
                        <VBox styleClass="form-card">
                            <padding>
                                <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
                            </padding>
                            <children>
                                <GridPane hgap="20.0" vgap="10.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" percentWidth="50.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" percentWidth="50.0" />
                                    </columnConstraints>
                                    <children>
                                        <Label styleClass="input-label" text="NÚMERO DE FACTURA" />
                                        <Label styleClass="input-label" text="SUCURSAL" GridPane.columnIndex="1" />

                                        <!-- Inputs Deshabilitados con ícono -->
                                        <HBox alignment="CENTER_LEFT" styleClass="input-container-disabled" GridPane.rowIndex="1">
                                            <children>
                                                <Label fx:id="lblIconFactura" styleClass="input-icon-font" style="-fx-font-size: 18px;" />
                                                <TextField fx:id="txtNumFactura" editable="false" styleClass="form-field" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>

                                        <HBox alignment="CENTER_LEFT" styleClass="input-container-disabled" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                            <children>
                                                <Label fx:id="lblIconSucursal" styleClass="input-icon-font" style="-fx-font-size: 18px;" />
                                                <TextField fx:id="txtSucursal" editable="false" styleClass="form-field" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <!-- Tarjeta 2: Tabla de Detalles -->
                        <VBox styleClass="form-card" VBox.vgrow="ALWAYS">
                            <children>
                                <TableView fx:id="tbDetalle" styleClass="custom-table" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colCodigo" prefWidth="150.0" text="CÓDIGO PRODUCTO" />
                                        <TableColumn fx:id="colDescripcion" prefWidth="400.0" text="DESCRIPCIÓN" />
                                        <TableColumn fx:id="colCantidad" prefWidth="100.0" style="-fx-alignment: CENTER;" text="CANTIDAD" />
                                        <TableColumn fx:id="colPUnitario" prefWidth="120.0" style="-fx-alignment: CENTER;" text="PRECIO UNITARIO" />
                                        <TableColumn fx:id="colSubtotal" prefWidth="120.0" style="-fx-alignment: CENTER;" text="SUBTOTAL" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>

                        <!-- Tarjeta 3: Resumen de Totales (Alineada a la derecha) -->
                        <HBox alignment="CENTER_RIGHT">
                            <children>
                                <VBox prefWidth="350.0" spacing="15.0" styleClass="form-card">
                                    <padding>
                                        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
                                    </padding>
                                    <children>

                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label style="-fx-font-size: 13px; -fx-text-fill: #555555; -fx-font-weight: bold;" text="SUBTOTAL NETO" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label fx:id="lblSubtotalNeto" style="-fx-font-size: 14px; -fx-text-fill: #333333; -fx-font-weight: bold;" text="\$0.00" />
                                            </children>
                                        </HBox>

                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <children>
                                                <Label style="-fx-font-size: 13px; -fx-text-fill: #555555; -fx-font-weight: bold;" text="IVA (12%)" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label fx:id="lblIva" style="-fx-font-size: 14px; -fx-text-fill: #333333; -fx-font-weight: bold;" text="\$0.00" />
                                            </children>
                                        </HBox>

                                        <!-- Línea separadora -->
                                        <Label style="-fx-min-height: 1px; -fx-pref-height: 1px; -fx-background-color: #E2E8F0; -fx-max-width: Infinity;">
                                            <VBox.margin>
                                                <Insets bottom="5.0" top="5.0" />
                                            </VBox.margin>
                                        </Label>

                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label styleClass="resumen-total-label" text="TOTAL" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label fx:id="lblTotalFacturado" style="-fx-font-size: 20px; -fx-text-fill: #00796B; -fx-font-weight: 900;" text="\$0.00" />
                                            </children>
                                        </HBox>

                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>