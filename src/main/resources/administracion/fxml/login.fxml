<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="700.0" prefWidth="900.0" styleClass="login-bg"
      stylesheets="@../css/loginStyles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.grupo1.sgsm.administracion.gestionUsuarios.controller.loginController">
    <children>

        <VBox alignment="CENTER" maxWidth="450.0" spacing="25.0" styleClass="login-card">
            <children>

                <!-- Logo Box -->
                <VBox alignment="CENTER" styleClass="logo-box" maxWidth="60.0" prefHeight="60.0">
                    <Label fx:id="lblLogoIcon" styleClass="logo-icon"/>
                </VBox>

                <!-- Títulos -->
                <VBox alignment="CENTER" spacing="5.0">
                    <Label styleClass="login-title" text="SPORT MASTER ECUADOR" textAlignment="CENTER"/>
                    <Label styleClass="login-subtitle" text="SISTEMA DE GESTIÓN CORPORATIVA"/>
                </VBox>

                <!-- Separador / Sección -->
                <HBox alignment="CENTER_LEFT" styleClass="section-title-container">
                    <VBox.margin>
                        <Insets top="10.0" bottom="10.0"/>
                    </VBox.margin>
                    <Label styleClass="section-line"/>
                    <Label styleClass="section-title" text="Iniciar Sesión"/>
                </HBox>

                <!-- Campo Usuario -->
                <VBox spacing="8.0">
                    <children>
                        <Label styleClass="login-label" text="Usuario"/>
                        <HBox alignment="CENTER_LEFT" styleClass="input-container">
                            <Label fx:id="lblUserIcon" styleClass="input-icon"/>
                            <TextField fx:id="txtUsuario" promptText="Ingrese su nombre de usuario" styleClass="login-field" HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </children>
                </VBox>

                <!-- Campo Contraseña -->
                <VBox spacing="8.0">
                    <children>
                        <Label styleClass="login-label" text="Contraseña"/>
                        <HBox alignment="CENTER_LEFT" styleClass="input-container">
                            <Label fx:id="lblPassIcon" styleClass="input-icon"/>

                            <StackPane alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                <children>
                                    <TextField fx:id="txtContrasenaVisible" promptText="........"
                                               styleClass="login-field" visible="false" managed="false"/>
                                    <PasswordField fx:id="txtContrasena" promptText="........"
                                                   styleClass="login-field"/>
                                </children>
                            </StackPane>

                            <!-- Botón de ojito -->
                            <Label fx:id="lblEyeIcon" styleClass="action-icon" onMouseClicked="#toggleMostrarContrasena"/>
                        </HBox>
                    </children>
                </VBox>

                <Label fx:id="lblMensaje" styleClass="error-message"/>

                <!-- Botón Iniciar Sesión-->
                <Button id="loginButton" fx:id="loginButton" defaultButton="true" maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false" onAction="#login" styleClass="login-btn">
                    <graphic>
                        <HBox alignment="CENTER" spacing="10.0">
                            <Label text="INGRESAR AL SISTEMA" styleClass="btn-text"/>
                            <Label fx:id="lblBtnIcon" styleClass="btn-icon"/>
                        </HBox>
                    </graphic>
                    <VBox.margin>
                        <Insets top="10.0"/>
                    </VBox.margin>
                </Button>

                <!-- Footer -->
                <VBox alignment="CENTER" spacing="2.0">
                    <VBox.margin>
                        <Insets top="20.0"/>
                    </VBox.margin>
                    <Label styleClass="footer-text" text="© 2026 Sport Master Ecuador. Reservados todos los derechos"/>
                    <Label styleClass="footer-text" text="Versión del Sistema: 5.4.2-Industrial"/>
                </VBox>
            </children>
        </VBox>
    </children>
</VBox>