                                          <VBox fx:id="parametrosBox" styleClass="contenedorMenu">
                                              <children>
                                                  <Button fx:id="btnParametros" alignment="TOP_LEFT" maxWidth="Infinity" mnemonicParsing="false" onAction="#toggleParametros" text="PARÁMETROS">
                                                      <styleClass>
                                                          <String fx:value="navBtn" />
                                                          <String fx:value="navBtnSubmenu" />
                                                          <String fx:value="navBtnSeparation" />
                                                      </styleClass>
                                                  </Button>
                                                  <VBox fx:id="parametrosSubMenu" managed="false" prefHeight="200.0" prefWidth="100.0" styleClass="submenu" visible="false">
                                                      <children>
                                                          <Button fx:id="btnRegistrarSucursal" alignment="TOP_LEFT" mnemonicParsing="false" onAction="#abrirRegistrarSucursal" text="REGISTRAR SUCURSAL">
                                                              <styleClass>
                                                                  <String fx:value="navBtn" />
                                                                  <String fx:value="navBtnSeparation" />
                                                              </styleClass>
                                                          </Button>
                                                          <Button fx:id="btnGestionParametros" alignment="TOP_LEFT" mnemonicParsing="false" onAction="#abrirGestionParametros" text="GESTIÓN DE PARÁMETROS">
                                                              <styleClass>
                                                                  <String fx:value="navBtn" />
                                                                  <String fx:value="navBtnSubmenu" />
                                                              </styleClass>
                                                          </Button>
                                                      </children>
                                                  </VBox>
                                              </children>
                                          </VBox>
                                    </children>
                                </VBox>

                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

                <!-- BOTÓN NUEVA VENTA (Añadido en la parte inferior del menú) -->
                <Button id="btnNuevaVenta" fx:id="btnNuevaVenta" layoutX="14.0" layoutY="585.0" mnemonicParsing="false" onAction="#abrirFacturacion" prefHeight="34.0" prefWidth="234.0" styleClass="btnNuevaVenta" text="NUEVA VENTA" />

                <!-- BOTONES DE SALIDA Y MAIN -->
                <Button id="btnLogOut" fx:id="btnLogOut" layoutX="14.0" layoutY="635.0" mnemonicParsing="false" onAction="#logOut" prefHeight="34.0" prefWidth="55.0" />
                <Button id="btnLogOut" fx:id="btnGoMain" layoutX="193.0" layoutY="635.0" mnemonicParsing="false" onAction="#goMain" prefHeight="34.0" prefWidth="55.0" />

            </children>
        </AnchorPane>

        <!-- CONTENEDOR PRINCIPAL PARA REEMPLAZAR CONTENIDO -->
        <Pane fx:id="contenedorPrincipal" layoutX="260.0" layoutY="36.0" prefHeight="686.0" prefWidth="1016.0" styleClass="imagenFondo" />

    </children>
</AnchorPane>
