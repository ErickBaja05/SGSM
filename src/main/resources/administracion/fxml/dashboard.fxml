                                                    </styleClass>
                                                </Button>
                                                <Button fx:id="btnConsultarCatalogo" alignment="TOP_LEFT" mnemonicParsing="false" onAction="#abrirConsultarCatálogo" text="CONSULTA CATÁLOGO">
                                                    <styleClass>
                                                        <String fx:value="navBtn" />
                                                        <String fx:value="navBtnSubmenu" />
                                                    </styleClass>
                                                </Button>
                                                <Button fx:id="btnMarketing" alignment="TOP_LEFT" mnemonicParsing="false" onAction="#abrirMarketing" text="INFORMACIÓN MARKETING">
                                                    <styleClass>
                                                        <String fx:value="navBtn" />
