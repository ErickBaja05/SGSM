<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane fx:id="rootPane" prefHeight="720.0" prefWidth="1280.0" stylesheets="@../../core/css/globalStyles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.grupo1.sgsm.administracion.dashboard.mainWindowController">

    <!-- ================= BARRA LATERAL IZQUIERDA ================= -->
    <left>
        <VBox id="navMenu" fx:id="sidebar" prefWidth="260.0" BorderPane.alignment="CENTER">
            <children>
                <!-- Perfil de Usuario (Fijo arriba) -->
                <VBox alignment="CENTER_LEFT" spacing="20.0">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="20.0" />
                    </padding>
                    <children>
                        <Label id="iconoUsuario" fx:id="iconoUsuario" alignment="CENTER" maxWidth="Infinity" />
                        <HBox spacing="10.0">
                            <Label styleClass="labelVentana" text="BIENVENIDO:" />
                            <Label fx:id="lblUsuario" styleClass="labelVentana" text="USUARIO" />
                        </HBox>
                        <HBox spacing="10.0">
                            <Label styleClass="labelVentana" text="ROL:" />
                            <Label fx:id="lblRol" styleClass="labelVentana" text="ADMINISTRADOR" />
                        </HBox>
                        <HBox spacing="10.0">
                            <Label styleClass="labelVentana" text="SEDE:" />
                            <Label fx:id="lblSede" styleClass="labelVentana" text="PRINCIPAL" />
                        </HBox>
                    </children>
                </VBox>

                <!-- Menú de Navegación (Con Scroll Dinámico) -->
                <!-- VBox.vgrow="ALWAYS" empuja al footer hacia abajo -->
                <ScrollPane id="navContenedor" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS" style="-fx-background: transparent; -fx-background-color: transparent;">
                    <content>
                        <VBox fx:id="menuBox" style="-fx-spacing: 15;">
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                            <children>
                                <!-- SECCIÓN CLIENTES -->
                                <VBox fx:id="clientesBox" styleClass="contenedorMenu">
                                    <Button fx:id="btnClientes" alignment="TOP_LEFT" maxWidth="Infinity" mnemonicParsing="false" onAction="#toggleClientes" styleClass="navBtn" text="CLIENTES" />
                                    <VBox fx:id="submenuClientes" managed="false" styleClass="submenu" visible="false">
                                        <Button fx:id="btnRegistrarCliente" alignment="TOP_LEFT" mnemonicParsing="false" onAction="#abrirRegistrarClientes" text="REGISTRAR NUEVO CLIENTE">
                                            <styleClass><String fx:value="navBtn" /><String fx:value="navBtnSeparation" /></styleClass>
                                        </Button>
                                        <Button fx:id="btnGestionClientes" alignment="TOP_LEFT" mnemonicParsing="false" onAction="#abrirGestionClientes" text="GESTIÓN DE CLIENTES">
                                            <styleClass><String fx:value="navBtn" /><String fx:value="navBtnSubmenu" /></styleClass>
                                        </Button>
                                    </VBox>
                                </VBox>

                                <!-- SECCIÓN PRODUCTOS -->
                                <VBox fx:id="productosBox" styleClass="contenedorMenu">
                                    <Button fx:id="btnProductos" alignment="TOP_LEFT" maxWidth="Infinity" mnemonicParsing="false" onAction="#toggleProductos" styleClass="navBtn" text="PRODUCTOS" />
                                    <VBox fx:id="submenuProductos" managed="false" styleClass="submenu" visible="false">
                                        <Button fx:id="btnCrearProducto" alignment="TOP_LEFT" mnemonicParsing="false" onAction="#abrirCrearProducto" text="REGISTRAR NUEVO PRODUCTO">
                                            <styleClass><String fx:value="navBtn" /><String fx:value="navBtnSeparation" /></styleClass>
                                        </Button>
                                        <Button fx:id="btnConsultarCatalogo" alignment="TOP_LEFT" mnemonicParsing="false" onAction="#abrirConsultarCatálogo" text="CONSULTA CATÁLOGO">
                                            <styleClass><String fx:value="navBtn" /><String fx:value="navBtnSubmenu" /></styleClass>
                                        </Button>
                                        <Button fx:id="btnMarketing" alignment="TOP_LEFT" mnemonicParsing="false" onAction="#abrirMarketing" text="INFORMACIÓN MARKETING">
                                            <styleClass><String fx:value="navBtn" /><String fx:value="navBtnSubmenu" /></styleClass>
                                        </Button>
                                        <Button fx:id="btnStockLocal" alignment="TOP_LEFT" mnemonicParsing="false" onAction="#abrirStockLocal" text="CONSULTAR STOCK LOCAL">
                                            <styleClass><String fx:value="navBtn" /><String fx:value="navBtnSubmenu" /></styleClass>
                                        </Button>
                                        <Button fx:id="btnStockRemoto" alignment="TOP_LEFT" mnemonicParsing="false" onAction="#abrirStockOtraSede" text="CONSULTAR STOCK SEDE ALTERNA">
                                            <styleClass><String fx:value="navBtn" /><String fx:value="navBtnSubmenu" /></styleClass>
                                        </Button>
                                        <Button fx:id="btnAjusteStock" alignment="TOP_LEFT" mnemonicParsing="false" onAction="#abrirAjusteStock" text="AJUSTE DE STOCK">
                                            <styleClass><String fx:value="navBtn" /><String fx:value="navBtnSubmenu" /></styleClass>
                                        </Button>
                                    </VBox>
                                </VBox>

                                <!-- SECCIÓN FACTURACIÓN -->
                                <VBox fx:id="facturacionBox" styleClass="contenedorMenu">
                                    <Button fx:id="btnFacturacion" alignment="TOP_LEFT" maxWidth="Infinity" mnemonicParsing="false" onAction="#toggleFacturacion" styleClass="navBtn" text="FACTURACIÓN" />
                                    <VBox fx:id="submenuFacturacion" managed="false" styleClass="submenu" visible="false">
                                        <Button fx:id="btnFacturarProductos" alignment="TOP_LEFT" mnemonicParsing="false" onAction="#abrirFacturacion" text="FACTURAR PRODUCTOS">
                                            <styleClass><String fx:value="navBtn" /><String fx:value="navBtnSeparation" /></styleClass>
                                        </Button>
                                        <Button fx:id="btnConsultarFacturas" alignment="TOP_LEFT" mnemonicParsing="false" onAction="#abrirConsultarFacturas" text="CONSULTAR FACTURAS">
                                            <styleClass><String fx:value="navBtn" /><String fx:value="navBtnSubmenu" /></styleClass>
                                        </Button>
                                    </VBox>
                                </VBox>

                                <!-- SECCIÓN ADMINISTRACIÓN -->
                                <VBox fx:id="administracionBox" styleClass="contenedorMenu">
                                    <Button fx:id="btnAdministracion" alignment="TOP_LEFT" maxWidth="Infinity" mnemonicParsing="false" onAction="#toggleAdministracion" styleClass="navBtn" text="ADMINISTRACIÓN" />

                                    <!-- SUBMENÚ GESTIÓN USUARIOS -->
                                    <VBox fx:id="usuariosBox" managed="false" styleClass="contenedorMenu" visible="false">
                                        <Button fx:id="btnUsuarios" alignment="TOP_LEFT" maxWidth="Infinity" mnemonicParsing="false" onAction="#toggleUsuarios" text="USUARIOS">
                                            <styleClass><String fx:value="navBtn" /><String fx:value="navBtnSubmenu" /><String fx:value="navBtnSeparation" /></styleClass>
                                        </Button>
                                        <VBox fx:id="usuariosSubMenu" managed="false" styleClass="submenu" visible="false">
                                            <Button fx:id="btnCrearUsuario" alignment="TOP_LEFT" mnemonicParsing="false" onAction="#abrirCrearUsuario" text="CREAR USUARIO">
                                                <styleClass><String fx:value="navBtn" /><String fx:value="navBtnSeparation" /></styleClass>
                                            </Button>
                                            <Button fx:id="btnGestionUsuarios" alignment="TOP_LEFT" mnemonicParsing="false" onAction="#abirGestionUsuarios" text="GESTIÓN DE USUARIOS">
                                                <styleClass><String fx:value="navBtn" /><String fx:value="navBtnSubmenu" /></styleClass>
                                            </Button>
                                        </VBox>
                                    </VBox>

                                    <!-- SUBMENÚ GESTIÓN PARÁMETROS -->
                                    <VBox fx:id="parametrosBox" managed="false" styleClass="contenedorMenu" visible="false">
                                        <Button fx:id="btnParametros" alignment="TOP_LEFT" maxWidth="Infinity" mnemonicParsing="false" onAction="#toggleParametros" text="PARÁMETROS">
                                            <styleClass><String fx:value="navBtn" /><String fx:value="navBtnSubmenu" /><String fx:value="navBtnSeparation" /></styleClass>
                                        </Button>
                                        <VBox fx:id="parametrosSubMenu" managed="false" styleClass="submenu" visible="false">
                                            <Button fx:id="btnRegistrarSucursal" alignment="TOP_LEFT" mnemonicParsing="false" onAction="#abrirRegistrarSucursal" text="REGISTRAR SUCURSAL">
                                                <styleClass><String fx:value="navBtn" /><String fx:value="navBtnSeparation" /></styleClass>
                                            </Button>
                                            <Button fx:id="btnGestionParametros" alignment="TOP_LEFT" mnemonicParsing="false" onAction="#abrirGestionParametros" text="GESTIÓN DE PARÁMETROS">
                                                <styleClass><String fx:value="navBtn" /><String fx:value="navBtnSubmenu" /></styleClass>
                                            </Button>
                                        </VBox>
                                    </VBox>
                                </VBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

                <!-- Footer (Fijo Abajo) -->
                <VBox alignment="CENTER" spacing="15.0">
                    <padding>
                        <Insets bottom="20.0" left="15.0" right="15.0" top="10.0" />
                    </padding>
                    <children>
                        <Button id="btnNuevaVenta" fx:id="btnNuevaVenta" maxWidth="Infinity" mnemonicParsing="false" onAction="#abrirFacturacion" styleClass="btnNuevaVenta" text="NUEVA VENTA"/>
                        <HBox alignment="CENTER" spacing="40.0">
                            <Button id="btnLogOut" fx:id="btnLogOut" mnemonicParsing="false" onAction="#logOut" styleClass="btnNavDown" />
                            <Button id="btnLogOut" fx:id="btnGoMain" mnemonicParsing="false" onAction="#goMain" styleClass="btnNavDown" />
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <!-- ================= ÁREA DE CONTENIDO (Centro) ================= -->
    <center>
        <BorderPane BorderPane.alignment="CENTER">
            <top>
                <!-- BARRA SUPERIOR -->
                <HBox id="top" alignment="CENTER_LEFT" prefHeight="40.0" spacing="10.0" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets left="20.0" right="20.0" />
                    </padding>
                    <children>
                        <Label fx:id="lblLogBalon" />
                        <Label id="lblTitulo" text="SISTEMA DE GESTIÓN PARA SPORTMASTER" />
                    </children>
                </HBox>
            </top>

            <!-- CONTENEDOR PRINCIPAL ESCALABLE -->
            <center>
                <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" BorderPane.alignment="CENTER">
                    <content>
                        <!-- Usamos StackPane en lugar de un simple Pane para que el contenido se estire -->
                        <StackPane fx:id="contenedorPrincipal" styleClass="imagenFondo" />
                    </content>
                </ScrollPane>
            </center>
        </BorderPane>
    </center>

</BorderPane>