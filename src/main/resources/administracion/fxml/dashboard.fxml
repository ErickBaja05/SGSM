                        <VBox fx:id="menuBox" prefHeight="233.0" prefWidth="246.0" style="-fx-spacing: 20;">
                            <children>

                                <!-- SECCIÓN CLIENTES -->
                                <VBox fx:id="clientesBox" prefHeight="200.0" prefWidth="100.0" styleClass="contenedorMenu">
                                    <children>
                                        <Button fx:id="btnClientes" alignment="TOP_LEFT" maxWidth="Infinity" mnemonicParsing="false" onAction="#toggleClientes" styleClass="navBtn" text="CLIENTES" />
                                        <VBox fx:id="submenuClientes" managed="false" prefHeight="200.0" prefWidth="100.0" styleClass="submenu" visible="false">
