<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="720.0" prefWidth="1280.0" stylesheets="@../css/dashboardStyles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.grupo1.sgsm.administracion.dashboard.mainWindowController">
    <children>
        <!-- BARRA SUPERIOR -->
        <AnchorPane id="top" layoutX="-3.0" prefHeight="33.0" prefWidth="1280.0">
            <children>
                <Label id="lblTitulo" layoutX="50.0" layoutY="8.0" text="SISTEMA DE GESTIÓN PARA SPORTMASTER" />
                <Label fx:id="lblLogBalon" layoutX="14.0" layoutY="7.0" text="Label" />
            </children>
        </AnchorPane>

        <!-- MENÚ DE NAVEGACIÓN LATERAL -->
        <AnchorPane id="navMenu" layoutY="36.0" prefHeight="686.0" prefWidth="260.0">
