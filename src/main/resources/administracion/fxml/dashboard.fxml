                <Label id="label" fx:id="lblUsuario" layoutX="110.0" layoutY="85.0" styleClass="labelVentana" text="USUARIO" />

                <Label layoutX="14.0" layoutY="110.0" styleClass="labelVentana" text="ROL:" />
                <Label fx:id="lblRol" layoutX="110.0" layoutY="110.0" styleClass="labelVentana" text="ADMIN" />

                <Label layoutX="14.0" layoutY="135.0" styleClass="labelVentana" text="SEDE:" />
                <Label fx:id="lblSede" layoutX="110.0" layoutY="135.0" styleClass="labelVentana" text="PRINCIPAL" />

                <!-- LÍNEA SEPARADORA AJUSTADA -->
                <Line endX="154.4" layoutX="76.0" layoutY="170.0" startX="-49.0">
                    <stroke>
                        <LinearGradient endX="0.37" endY="0.58" startX="0.69" startY="0.24">
                            <stops>
                                <Stop>
                                    <color><Color red="0.27" green="0.66" blue="0.30" opacity="0.87" /></color>
                                </Stop>
                                <Stop offset="1.0">
                                    <color><Color red="0.45" green="0.39" blue="0.39" /></color>
                                </Stop>
                            </stops>
                        </LinearGradient>
                    </stroke>
                </Line>
                <!-- LÍNEA SEPARADORA AJUSTADA (Esta se mantiene igual, en Y=170) -->
                <Line endX="154.4" layoutX="76.0" layoutY="170.0" startX="-49.0">
                    <stroke>
                        <LinearGradient endX="0.37" endY="0.58" startX="0.69" startY="0.24">
                            <stops>
                                <Stop>
                                    <color><Color red="0.27" green="0.66" blue="0.30" opacity="0.87" /></color>
                                </Stop>
                                <Stop offset="1.0">
                                    <color><Color red="0.45" green="0.39" blue="0.39" /></color>
                                </Stop>
                            </stops>
                        </LinearGradient>
                    </stroke>
                </Line>

                <!-- EL SCROLLPANE CORREGIDO: layoutY="190.0" lo baja por debajo de la línea -->
