<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToHeight="true" fitToWidth="true" styleClass="scroll-pane-transparent" stylesheets="@../../core/css/globalStyles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.grupo1.sgsm.administracion.gestionUsuarios.controller.gestionUsuariosController">
    <content>
        <VBox alignment="TOP_CENTER" styleClass="main-bg">
            <children>
                <!-- Contenedor Principal Responsivo -->
                <VBox alignment="TOP_LEFT" maxWidth="1200.0" minHeight="600.0" spacing="20.0" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
                    </padding>
                    <children>

                        <!-- Títulos -->
                        <VBox spacing="2.0">
                            <children>
                                <Label styleClass="page-title" text="GESTIÓN DE USUARIOS" />
                                <Label styleClass="page-subtitle" text="Administración y control de accesos para el personal del sistema." />
                            </children>
                        </VBox>

                        <!-- Búsqueda y Resumen -->
                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                            <children>
                                <!-- Barra de Búsqueda -->
                                <HBox alignment="CENTER_LEFT" styleClass="search-container" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="lblSearchIcon" styleClass="search-icon-font" />
                                        <TextField fx:id="txtBuscar" promptText="Buscar usuario por nombre o rol..." styleClass="search-field" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>

                                <!-- Totales simplificados -->
                                <HBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #E8F0FE; -fx-padding: 8 15; -fx-background-radius: 6;">
                                    <children>
                                        <Label style="-fx-font-size: 12px; -fx-text-fill: #555555; -fx-font-weight: bold;" text="TOTAL USUARIOS:" />
                                        <Label fx:id="lblTotalUsuarios" style="-fx-font-size: 14px; -fx-text-fill: #1967D2; -fx-font-weight: 900;" text="0" />

                                        <Label style="-fx-text-fill: #B0BEC5;" text="|" />

                                        <Label style="-fx-font-size: 12px; -fx-text-fill: #555555; -fx-font-weight: bold;" text="ADMINISTRADORES:" />
                                        <Label fx:id="lblTotalAdmins" style="-fx-font-size: 14px; -fx-text-fill: #1967D2; -fx-font-weight: 900;" text="0" />
                                    </children>
                                </HBox>
                            </children>
                        </HBox>

                        <!-- Área Dividida: Tabla (Izquierda) y Edición (Derecha) -->
                        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                            <children>

                                <!-- Contenedor de la Tabla -->
                                <VBox spacing="10.0" styleClass="form-card" HBox.hgrow="ALWAYS">
                                    <padding>
                                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                                    </padding>
                                    <children>
                                        <Label styleClass="header-title" text="LISTA DE USUARIOS" />
                                        <TableView fx:id="tbUsuarios" styleClass="custom-table" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colId" prefWidth="100.0" text="ID" />
                                                <TableColumn fx:id="colUsuario" prefWidth="200.0" text="USUARIO" />
                                                <TableColumn fx:id="colRol" prefWidth="150.0" text="ROL" />
                                                <TableColumn fx:id="colCorreo" prefWidth="250.0" text="CORREO" />
                                            </columns>
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                            </columnResizePolicy>
                                        </TableView>
                                    </children>
                                </VBox>

                                <!-- Tarjeta de Edición de Usuario -->
                                <VBox minWidth="320.0" prefWidth="340.0" spacing="20.0" styleClass="form-card, card-accent-top">
                                    <padding>
                                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                                    </padding>
                                    <children>

                                        <!-- Cabecera de Edición -->
                                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                                            <children>
                                                <VBox alignment="CENTER" style="-fx-background-color: #E0F2F1; -fx-background-radius: 8; -fx-padding: 10;">
                                                    <children>
                                                        <Label fx:id="lblEditHeaderIcon" style="-fx-text-fill: #00796B; -fx-font-size: 20px;" />
                                                    </children>
                                                </VBox>
                                                <VBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #111111;" text="Editar Usuario" />
                                                        <Label fx:id="lblEditId" style="-fx-font-size: 11px; -fx-text-fill: #888888;" text="ID: -" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <!-- LÍNEA SEPARADORA CORREGIDA (100% COMPATIBLE CON SCENE BUILDER) -->
                                        <Label maxWidth="1.7976931348623157E308" minHeight="1.0" prefHeight="1.0" style="-fx-background-color: #E2E8F0;" />

                                        <!-- Formulario -->
                                        <VBox spacing="15.0" VBox.vgrow="ALWAYS">
                                            <children>
                                                <VBox spacing="5.0">
                                                    <children>
                                                        <Label styleClass="input-label" text="NOMBRE DE USUARIO" />
                                                        <TextField fx:id="txtEditUsuario" styleClass="form-field-standalone" />
                                                    </children>
                                                </VBox>

                                                <VBox spacing="5.0">
                                                    <children>
                                                        <Label styleClass="input-label" text="CORREO ELECTRÓNICO" />
                                                        <TextField fx:id="txtEditCorreo" styleClass="form-field-standalone" />
                                                    </children>
                                                </VBox>

                                                <VBox spacing="5.0">
                                                    <children>
                                                        <Label styleClass="input-label" text="ROL DEL SISTEMA" />
                                                        <ComboBox fx:id="cmbEditRol" maxWidth="1.7976931348623157E308" styleClass="custom-combo-box" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>

                                        <Label fx:id="lblMensajeConfirmacion" alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="mensaje-confirmacion" />

                                        <!-- Botones de Acción -->
                                        <VBox spacing="10.0">
                                            <children>
                                                <Button fx:id="btnModificar" disable="true" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#modificarUsuario" styleClass="btn-primary" style="-fx-padding: 10;">
                                                    <graphic>
                                                        <HBox alignment="CENTER" spacing="8.0">
                                                            <Label fx:id="lblBtnModificarIcon" styleClass="btn-primary-icon-font" />
                                                            <Label styleClass="btn-primary-text" text="Modificar Usuario" />
                                                        </HBox>
                                                    </graphic>
                                                </Button>
                                                <Button fx:id="btnEliminar" disable="true" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#eliminarUsuario" styleClass="btn-danger-outline" style="-fx-padding: 10;">
                                                    <graphic>
                                                        <HBox alignment="CENTER" spacing="8.0">
                                                            <Label fx:id="lblBtnEliminarIcon" styleClass="btn-danger-icon-font" />
                                                            <Label styleClass="btn-danger-text" text="Eliminar Usuario" />
                                                        </HBox>
                                                    </graphic>
                                                </Button>
                                            </children>
                                        </VBox>

                                    </children>
                                </VBox>

                            </children>
                        </HBox>

                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>