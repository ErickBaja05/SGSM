<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToHeight="true" fitToWidth="true" styleClass="scroll-pane-transparent" stylesheets="@../../core/css/globalStyles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.grupo1.sgsm.administracion.gestionParametros.controller.registrarSucursalController">
    <content>
        <VBox alignment="TOP_CENTER" styleClass="main-bg">
            <children>
                <!-- Contenedor Responsivo -->
                <VBox alignment="TOP_LEFT" maxWidth="900.0" spacing="25.0" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
                    </padding>
                    <children>

                        <!-- Títulos y Línea Verde Decorativa -->
                        <VBox spacing="10.0">
                            <children>
                                <VBox spacing="2.0">
                                    <children>
                                        <Label styleClass="page-title" text="REGISTRAR NUEVA SUCURSAL" />
                                        <Label styleClass="page-subtitle" text="Registrar nueva sucursal en el sistema" />
                                    </children>
                                </VBox>
                                <!-- La línea verde del mockup -->
                                <Label minHeight="4.0" prefHeight="4.0" prefWidth="80.0" style="-fx-background-color: #00796B;" />
                            </children>
                        </VBox>

                        <!-- Tarjeta Principal del Formulario -->
                        <VBox styleClass="form-card" VBox.vgrow="ALWAYS">
                            <children>

                                <!-- Cabecera de la Tarjeta -->
                                <HBox alignment="CENTER_LEFT" styleClass="card-header">
                                    <padding>
                                        <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
                                    </padding>
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #8898AA; -fx-font-size: 11px;" text="INFORMACIÓN ESTRUCTURAL" />
                                    </children>
                                </HBox>

                                <!-- Cuerpo del Formulario -->
                                <VBox spacing="25.0">
                                    <padding>
                                        <Insets bottom="30.0" left="30.0" right="30.0" top="25.0" />
                                    </padding>
                                    <children>

                                        <!-- GridPane sin rowConstraints para que no se achate -->
                                        <GridPane hgap="25.0" vgap="20.0">
                                            <columnConstraints>
                                                <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" percentWidth="50.0" />
                                                <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" percentWidth="50.0" />
                                            </columnConstraints>
                                            <children>

                                                <!-- CÓDIGO DE SUCURSAL -->
                                                <VBox spacing="5.0">
                                                    <children>
                                                        <Label styleClass="input-label" text="Código de Sucursal " />
                                                        <TextField fx:id="txtCodigo" promptText="Ej: CUE" styleClass="form-field-standalone" />
                                                    </children>
                                                </VBox>

                                                <!-- DIRECCIÓN PRINCIPAL -->
                                                <VBox spacing="5.0" GridPane.columnIndex="1">
                                                    <children>
                                                        <Label styleClass="input-label" text="Dirección Principal" />
                                                        <TextField fx:id="txtDireccion" promptText="Av. Amazonas y Naciones Unidas" styleClass="form-field-standalone" />
                                                    </children>
                                                </VBox>

                                                <!-- NOMBRE OFICIAL -->
                                                <VBox spacing="5.0" GridPane.rowIndex="1">
                                                    <children>
                                                        <Label styleClass="input-label" text="Nombre Oficial" />
                                                        <TextField fx:id="txtNombre" promptText="Ej: Sucursal Norte Quitumbe" styleClass="form-field-standalone" />
                                                    </children>
                                                </VBox>

                                                <!-- TELÉFONO -->
                                                <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                                    <children>
                                                        <Label styleClass="input-label" text="Teléfono" />
                                                        <TextField fx:id="txtTelefono" promptText="+593 (02) 2345-678" styleClass="form-field-standalone" />
                                                    </children>
                                                </VBox>
                                    <VBox spacing="5.0" GridPane.columnSpan="2" GridPane.rowIndex="2">
                                       <children>
                                          <Label styleClass="input-label" text="Ciudad" />
                                          <TextField fx:id="txtCiudad" promptText="Ej: Esmeraldas" styleClass="form-field-standalone" />
                                       </children>
                                    </VBox>

                                            </children>
                                 <rowConstraints>
                                    <RowConstraints />
                                    <RowConstraints />
                                    <RowConstraints minHeight="10.0" prefHeight="30.0" />
                                 </rowConstraints>
                                        </GridPane>

                                        <!-- Caja de Notificación (Borde verde a la izquierda) -->
                                        <VBox spacing="5.0" style="-fx-background-color: #E8F0FE; -fx-border-color: transparent transparent transparent #00796B; -fx-border-width: 0 0 0 3px; -fx-padding: 15;">
                                            <children>
                                                <Label style="-fx-font-weight: 900; -fx-text-fill: #00796B; -fx-font-size: 11px;" text="NOTIFICACIÓN DEL SISTEMA" />
                                                <Label style="-fx-text-fill: #555555; -fx-font-size: 13px;" text="Comuníquese con el Administrador del Sistema para la configuración de infraestructura necesaria al registrar una nueva sede." wrapText="true" />
                                            </children>
                                            <VBox.margin>
                                                <Insets top="10.0" />
                                            </VBox.margin>
                                        </VBox>

                                        <!-- Separador sutil -->
                                        <Label maxWidth="1.7976931348623157E308" minHeight="1.0" prefHeight="1.0" style="-fx-background-color: #F0F4F8;">
                                            <VBox.margin>
                                                <Insets bottom="10.0" top="10.0" />
                                            </VBox.margin>
                                        </Label>

                                        <!-- Footer con Botones -->
                                        <HBox alignment="CENTER_RIGHT" spacing="20.0">
                                            <children>
                                                <Label fx:id="mensajeConfirmacion" styleClass="mensaje-confirmacion" />
                                                <Button fx:id="btnCancelar" mnemonicParsing="false" onAction="#cancelarOperacion" styleClass="btn-secondary" text="CANCELAR" />
                                                <Button fx:id="btnRegistrar" mnemonicParsing="false" onAction="#registrarSucursal" style="-fx-padding: 12 30; -fx-font-size: 14px;" styleClass="btn-primary">
                                                    <graphic>
                                                        <HBox alignment="CENTER" spacing="8.0">
                                                            <Label fx:id="lblBtnRegistrarIcon" styleClass="btn-primary-icon-font" />
                                                            <Label style="-fx-font-size: 13px;" styleClass="btn-primary-text" text="REGISTRAR" />
                                                        </HBox>
                                                    </graphic>
                                                </Button>
                                            </children>
                                        </HBox>

                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
