<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="700.0" prefWidth="900.0" styleClass="main-bg" stylesheets="@../css/productosStyles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.grupo1.sgsm.inventarioYproductos.controller.crearProductoController">
    <children>
        <VBox alignment="TOP_LEFT" maxWidth="800.0" spacing="5.0" VBox.vgrow="ALWAYS">
            <children>

                <!-- Títulos Principales -->
                <Label styleClass="page-title" text="REGISTRAR NUEVO PRODUCTO" />
                <Label styleClass="page-subtitle" text="Ingrese los datos para registrar un nuevo artículo en el catálogo">
                    <VBox.margin>
                        <Insets bottom="20.0" />
                    </VBox.margin>
                </Label>

                <!-- Tarjeta del Formulario -->
                <VBox styleClass="form-card" VBox.vgrow="ALWAYS">
                    <children>

                        <!-- Cabecera de la tarjeta -->
                        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="card-header">
                            <children>
                                <Label fx:id="lblHeaderIcon" styleClass="header-icon" />
                                <Label styleClass="header-title" text="Información del Producto" />
                            </children>
                            <padding>
                                <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
                            </padding>
                        </HBox>

                        <!-- Cuerpo del Formulario -->
                        <GridPane hgap="20.0" vgap="15.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" percentWidth="50.0" />
                                <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" percentWidth="50.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="60.0" vgrow="SOMETIMES" /> <!-- Fila más alta para el TextArea -->
                                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                            </rowConstraints>
                            <padding>
                                <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
                            </padding>
                            <children>

                                <!-- Código de Producto -->
                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="input-label" text="CÓDIGO DE PRODUCTO" />
                                        <HBox fx:id="boxCodigo" alignment="CENTER_LEFT" styleClass="input-container">
                                            <children>
                                                <Label fx:id="lblCodigoIcon" styleClass="input-icon" />
                                                <TextField fx:id="txtCodigo" promptText="PROD-1024" styleClass="form-field" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                        <Label styleClass="helper-text" text="Ingrese el código único del producto." />
                                    </children>
                                </VBox>

                                <!-- Categoría -->
                                <VBox spacing="5.0" GridPane.columnIndex="1">
                                    <children>
                                        <Label styleClass="input-label" text="CATEGORÍA" />
                                        <ComboBox fx:id="cmbCategoria" maxWidth="1.7976931348623157E308" promptText="Seleccione una categoría" styleClass="custom-combo-box" />
                                    </children>
                                </VBox>

                                <!-- Nombre del Producto -->
                                <VBox spacing="5.0" GridPane.rowIndex="1">
                                    <children>
                                        <Label styleClass="input-label" text="NOMBRE DEL PRODUCTO" />
                                        <TextField fx:id="txtNombre" promptText="Zapatillas Running Pro Elite" styleClass="form-field-standalone" />
                                    </children>
                                </VBox>

                                <!-- Marca -->
                                <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <children>
                                        <Label styleClass="input-label" text="MARCA" />
                                        <TextField fx:id="txtMarca" promptText="Nike" styleClass="form-field-standalone" />
                                    </children>
                                </VBox>

                                <!-- Descripción (Ocupa 2 columnas) -->
                                <VBox spacing="5.0" GridPane.columnSpan="2" GridPane.rowIndex="2">
                                    <children>
                                        <Label styleClass="input-label" text="DESCRIPCIÓN" />
                                        <TextArea fx:id="txtDescripcion" prefRowCount="3" promptText="Zapatillas de alto rendimiento..." styleClass="custom-text-area" wrapText="true" VBox.vgrow="ALWAYS" />
                                    </children>
                                </VBox>

                                <!-- Subtítulo Detalles de Precio -->
                                <Label styleClass="section-subtitle" text="DETALLES DE PRECIO" GridPane.columnSpan="2" GridPane.rowIndex="3">
                                    <GridPane.margin>
                                        <Insets top="10.0" />
                                    </GridPane.margin>
                                </Label>

                                <!-- Precio de Venta (Ocupa 2 columnas según mockup) -->
                                <VBox spacing="5.0" GridPane.columnSpan="2" GridPane.rowIndex="4">
                                    <children>
                                        <Label styleClass="input-label" text="PRECIO DE VENTA (USD)" />
                                        <HBox fx:id="boxPrecio" alignment="CENTER_LEFT" styleClass="input-container">
                                            <children>
                                                <Label fx:id="lblPrecioIcon" styleClass="input-icon" />
                                                <TextField fx:id="txtPrecio" promptText="125.00" styleClass="form-field" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                            </children>
                        </GridPane>

                        <!-- Contenedor de Botones Inferiores -->
                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                            <children>
                                <Button fx:id="btnRegistrar" mnemonicParsing="false" onAction="#registrarProducto" styleClass="btn-primary">
                                    <graphic>
                                        <HBox alignment="CENTER" spacing="8.0">
                                            <children>
                                                <Label fx:id="lblBtnRegistrarIcon" styleClass="btn-primary-icon-font" />
                                                <Label styleClass="btn-primary-text" text="REGISTRAR PRODUCTO" />
                                            </children>
                                        </HBox>
                                    </graphic>
                                </Button>
                                <Button fx:id="btnCancelar" mnemonicParsing="false" onAction="#cancelarOperacion" styleClass="btn-secondary" text="CANCELAR OPERACIÓN" />
                            </children>
                            <VBox.margin>
                                <Insets bottom="10.0" left="25.0" right="25.0" top="5.0" />
                            </VBox.margin>
                        </HBox>

                        <!-- Mensaje de Confirmación centrado -->
                        <HBox alignment="CENTER">
                            <children>
                                <Label fx:id="mensajeConfirmacion" styleClass="mensaje-confirmacion" />
                            </children>
                            <VBox.margin>
                                <Insets bottom="20.0" left="25.0" right="25.0" top="5.0" />
                            </VBox.margin>
                        </HBox>

                    </children>
                </VBox>
            </children>
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
            </padding>
        </VBox>
    </children>
</VBox>